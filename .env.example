# Agent Army environment variables
# Copy to .env and fill in values

# Telegram — Coding Orchestrator bot (user-facing army gateway)
# Reuse the existing "Coding Orchestrator - LangChain" bot — get token from BotFather
ARMY_BOT_TOKEN=your-bot-token-here
ARMY_ALLOWED_CHAT_IDS=your-telegram-chat-id

# OpenAI API key (shared across all projects — same key as agent-factory and ai-tech-lead)
OPENAI_API_KEY=your-openai-key-here

# LangSmith tracing (optional)
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agent-army-local

# Path to agent-factory project root (defaults to ~/projects/agent-factory)
# Only set if agent-factory lives somewhere else.
# AGENT_FACTORY_ROOT=/home/youruser/projects/agent-factory
