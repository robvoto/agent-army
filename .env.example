# Agent Army environment variables
# Copy to .env and fill in values

# Telegram bot token for the Army (reuse TELEGRAM_FACTORY_TOKEN — see AF-024)
ARMY_BOT_TOKEN=replace-with-your-bot-token

# OpenAI API key (shared with agent-factory)
OPENAI_API_KEY=replace-with-your-openai-key

# Comma-separated Telegram chat IDs allowed to use the army (leave empty to allow all)
ARMY_ALLOWED_CHAT_IDS=

# Path to the agent-factory project root (defaults to ~/projects/agent-factory)
# Only set this if agent-factory lives somewhere else.
# AGENT_FACTORY_ROOT=/home/youruser/projects/agent-factory
